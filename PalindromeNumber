public class PalindromeArray {
    public static boolean isPalindrome(int n) {
        int original = n;
        int reversed = 0;
        int num = n;
        while (num > 0) {
            int digit = num % 10;
            reversed = reversed * 10 + digit;
            num /= 10;
        }
        return original == reversed;
    }
    public static boolean allPalindrome(int[] arr) {
        for (int num : arr) {
            if (!isPalindrome(num)) {
                return false;
            }
        }
        return true;
    }
